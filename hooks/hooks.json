{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/notify_ble.py reset"
      }
    ],
    "sessionEnd": [
      {
        "command": ".cursor/hooks/notify_ble.py idle"
      }
    ],
    "afterAgentThought": [
      {
        "command": ".cursor/hooks/hook_parse.sh thinking"
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/hook_parse.sh working"
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/notify_ble.py working"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/notify_ble.py idle"
      }
    ],
    "postToolUseFailure": [
      {
        "command": ".cursor/hooks/notify_ble.py error"
      }
    ]
  }
}
