{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/notify.sh reset"
      }
    ],
    "sessionEnd": [
      {
        "command": ".cursor/hooks/notify.sh idle"
      }
    ],
    "afterAgentThought": [
      {
        "command": ".cursor/hooks/notify.sh thinking"
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/notify.sh working"
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/notify.sh working"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/notify.sh idle"
      }
    ],
    "postToolUseFailure": [
      {
        "command": ".cursor/hooks/on_error.sh"
      }
    ]
  }
}
